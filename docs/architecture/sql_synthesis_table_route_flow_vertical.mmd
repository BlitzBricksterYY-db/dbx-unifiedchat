graph TD
    Plan[Execution plan<br/>join_strategy = table_route]
    TableAgent[SQL Synthesis Table Agent]
    Check{Enough metadata?}
    Tools[UC function toolkit]
    Summary[get_space_summary]
    Overview[get_table_overview]
    Column[get_column_detail]
    Details[get_space_details<br/>last resort]
    Gathered[Relevant table metadata]
    Draft[Draft SQL]
    Reflect[Reflection + get_space_instructions]
    Final[Final SQL blocks<br/>with explanation]

    Plan --> TableAgent --> Check
    Check -->|Yes| Draft --> Reflect --> Final
    Check -->|No| Tools
    Tools --> Summary --> Gathered
    Tools --> Overview --> Gathered
    Tools --> Column --> Gathered
    Tools --> Details --> Gathered
    Gathered --> Draft

    classDef agentClass fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef dataClass fill:#50C878,stroke:#2E7D4E,stroke-width:2px,color:#fff
    classDef processClass fill:#F5A623,stroke:#C17D11,stroke-width:2px,color:#000
    classDef decisionClass fill:#8E44AD,stroke:#6C3483,stroke-width:2px,color:#fff

    class TableAgent agentClass
    class Plan,Gathered,Final dataClass
    class Tools,Summary,Overview,Column,Details,Draft,Reflect processClass
    class Check decisionClass
