graph TD
    Query[User query]
    Planner[Planning Agent]
    VS[Vector Search<br/>Genie space index]
    Spaces[Relevant spaces<br/>space_id + title + score]
    Analysis[Analyze question clarity<br/>scope and join need]
    Clear{Question clear?}
    Clarify[Clarification request]
    Route{Execution route}
    Single[Single-space plan]
    Multi[Multi-space no-join plan]
    Table[SQL synthesis table route plan]
    Genie[SQL synthesis genie route plan]
    Output[Execution plan JSON<br/>sub_questions + relevant_space_ids<br/>requires_join + join_strategy]

    Query --> Planner --> VS --> Spaces --> Analysis --> Clear
    Clear -->|No| Clarify
    Clear -->|Yes| Route
    Route -->|Single space| Single --> Output
    Route -->|Multi, no join| Multi --> Output
    Route -->|Join, table route| Table --> Output
    Route -->|Join, genie route| Genie --> Output

    classDef agentClass fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef dataClass fill:#50C878,stroke:#2E7D4E,stroke-width:2px,color:#fff
    classDef processClass fill:#F5A623,stroke:#C17D11,stroke-width:2px,color:#000
    classDef decisionClass fill:#8E44AD,stroke:#6C3483,stroke-width:2px,color:#fff

    class Planner agentClass
    class VS,Spaces,Output dataClass
    class Query,Analysis,Clarify,Single,Multi,Table,Genie processClass
    class Clear,Route decisionClass
