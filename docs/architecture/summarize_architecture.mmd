%%{init: {"theme":"base","themeVariables":{"background":"#ffffff"}}}%%
graph TB
    %% ============================================================
    %% Summarize Node / ResultSummarizeAgent Architecture
    %% ============================================================

    Start[🔀 Upstream Workflow<br/>Planning / SQL Synthesis / SQL Execution] -->|All terminal paths route here| SumNode[🧠 summarize_node<br/>Final LangGraph Node]
    SumNode --> End[✅ END]

    %% ============================================================
    %% Summarization Module
    %% ============================================================
    subgraph SummarizeModule["📦 Summarization Module (CURRENT)"]
        direction TB

        SumNode --> BuildArtifacts["Normalize result artifacts<br/>_build_artifact_entries()"]
        SumNode --> ExtractContext["Trim state for summary<br/>extract_summarize_context()"]
        ExtractContext --> TruncateMsgs[Keep system messages +<br/>last 5 conversation turns]

        SumNode --> Writer["🌊 Stream Writer<br/>get_stream_writer()"]
        Writer --> StepEvents[summary_start / summarize_step /<br/>text_delta / summary_complete]

        SumNode --> CacheAgent["Cache summarize agent<br/>get_cached_summarize_agent()"]
        CacheAgent --> Config["⚙️ get_config()<br/>summarize_endpoint / chart_endpoint / detect_code_lookup_endpoint"]
        Config --> SummaryLLM[(🤖 ChatDatabricks<br/>Summary LLM)]
        CacheAgent --> ResultAgent[📝 ResultSummarizeAgent]
        SummaryLLM --> ResultAgent

        BuildArtifacts --> ParallelHub{Parallel fan-out}
        ResultAgent --> PromptBuild["Build narrative-only prompt<br/>_build_summary_prompt()"]
        PromptBuild --> StreamSummary[Stream markdown summary]
        Writer -.streams.-> StreamSummary

        ParallelHub --> ChartBG[📊 Background chart generation]
        ParallelHub --> EnrichBG[🔎 Background code enrichment]

        ChartBG --> ChartGen["ChartGenerator.generate_chart()"]
        Config --> ChartLLM[(📈 Chart LLM)]
        ChartLLM --> ChartGen
        ChartGen --> ChartBlock["echarts-chart blocks<br/>per successful result"]

        EnrichBG --> DetectCodes[Detect coded columns]
        Config --> LookupLLM[(🔍 Cheap lookup LLM)]
        LookupLLM --> DetectCodes
        DetectCodes --> WebSearch[Web/code lookup enrichment]
        WebSearch --> CodeRef[Collapsible code reference]

        StreamSummary --> SummaryDraft[📄 Base summary text]
        ChartBlock --> Compose[Append charts + tables + accordions]
        CodeRef --> Compose
        SummaryDraft --> Compose
        BuildArtifacts --> TableBlocks["table-download blocks<br/>preview rows + CSV metadata"]
        TableBlocks --> Compose
        BuildArtifacts --> SqlBlocks["Show SQL / SQL Explanation<br/>Plan Executed accordions"]
        SqlBlocks --> Compose

        Compose --> FinalSummary[📦 final_summary]
        Compose --> FinalMessage[💬 AIMessage<br/>summary content]
    end

    %% Frontend / Output
    Writer --> Frontend[🖥️ Frontend Stream Renderer]
    FinalSummary --> Frontend
    FinalMessage --> End
    Frontend --> User[👤 User]

    %% Observability
    MLflow[📈 MLflow tracing<br/>via wrapped graph node] -.trace/span.-> SumNode

