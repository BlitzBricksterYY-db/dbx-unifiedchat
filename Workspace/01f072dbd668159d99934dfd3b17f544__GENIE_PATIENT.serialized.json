  "instructions": {
    "text_instructions": [
      {
        "id": "01f07464f0ea131f822a4694f86cb824",
        "content": [
          "Do not provide patient_ids in the query results. Only provide counts of distinct patient_ids in query results.\r\n",
          "\r\n",
          "Never show patient count results that are < 10. If a result is less than 10 return 'Count is less than 10'.\r\n",
          "\r\n",
          "Patients over the age 0f 89 should be aggregated to \"age 90 and over\"\r\n",
          "\r\n",
          "Self Pay is the same thing as uninsured\r\n",
          "\r\n",
          "When searching for uninsured patients find patients that are not present in the insurance table\r\n",
          "\r\n",
          "Always ask for physician first and last name\r\n",
          "\r\n",
          "Make physicians names case insenstive\r\n",
          "\r\n",
          "Only consider the first integer for any biospesimen samples for specimen counts"
        ]
      }
    ]
